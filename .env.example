# Turso (SQLite na nuvem) – usado na Vercel para persistir artilharia/gols.
# Crie um banco em https://turso.tech e preencha abaixo.
# Sem essas variáveis, o app usa arquivo local (data/gols.json) – não funciona na Vercel.
# TURSO_DATABASE_URL=libsql://seu-db-seu-user.turso.io
# TURSO_AUTH_TOKEN=seu-token
