# Turso (SQLite na nuvem) – usado na Vercel para persistir artilharia/gols.
# Crie um banco em https://turso.tech e preencha abaixo.
# Sem essas variáveis, o app usa arquivo local (data/gols.json) – não funciona na Vercel.
# TURSO_DATABASE_URL=libsql://seu-db-seu-user.turso.io
# TURSO_AUTH_TOKEN=seu-token

# Admin (edição de gols/destaques na página /gols e rotas de escrita protegidas).
# Em desenvolvimento, se ADMIN_PASSWORD estiver vazio, o padrão é usuário "admin" / senha "admin".
# Em produção, defina senha forte e um segredo longo e aleatório para o cookie assinado.
# ADMIN_USER=admin
# ADMIN_PASSWORD=gere-uma-senha-forte
# ADMIN_SESSION_SECRET=gere-uma-string-longa-aleatoria
